---
services:
  broker:
    image: "{{ paperless_redis_image }}:{{ paperless_redis_tag }}"
    restart: unless-stopped
    volumes:
      - "{{ paperless_data_path }}/redis:/data"

  db:
    image: "{{ paperless_postgres_image }}:{{ paperless_postgres_tag }}"
    restart: unless-stopped
    volumes:
      - "{{ paperless_data_path }}/postgres:/var/lib/postgresql/data"
    environment:
      POSTGRES_DB: "{{ paperless_db_name }}"
      POSTGRES_USER: "{{ paperless_db_user }}"
      POSTGRES_PASSWORD: "{{ paperless_db_password }}"

  webserver:
    image: "{{ paperless_image }}:{{ paperless_image_tag }}"
    container_name: "{{ paperless_web_container_name }}"
    restart: unless-stopped
    depends_on:
      - db
      - broker
    ports:
      - "127.0.0.1:{{ paperless_web_port }}:8000"
    volumes:
      - "{{ paperless_data_path }}/data:/usr/src/paperless/data"
      - "{{ paperless_data_path }}/media:/usr/src/paperless/media"
      - "{{ paperless_data_path }}/export:/usr/src/paperless/export"
      - "{{ paperless_data_path }}/consume:/usr/src/paperless/consume"
    environment:
      PAPERLESS_REDIS: redis://broker:6379
      PAPERLESS_DBHOST: db
      PAPERLESS_DBNAME: "{{ paperless_db_name }}"
      PAPERLESS_DBUSER: "{{ paperless_db_user }}"
      PAPERLESS_DBPASS: "{{ paperless_db_password }}"
      PAPERLESS_SECRET_KEY: "{{ paperless_secret_key }}"
      PAPERLESS_URL: "{{ paperless_url }}"
      PAPERLESS_TIME_ZONE: "{{ paperless_time_zone | default('UTC') }}"
      PAPERLESS_OCR_LANGUAGE: "{{ paperless_ocr_language | default('eng') }}"
